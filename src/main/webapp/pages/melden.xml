<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:h="http://xmlns.jcp.org/jsf/html"
      xmlns:f="http://xmlns.jcp.org/jsf/core"
      xmlns:p="http://primefaces.org/ui">
<h:head>
    <title>Geisternetz melden - Shea Sepherd</title>
</h:head>
<h:body>
    <h1>Geisternetz melden</h1>
    <a href="/ghostnet/">Zurück zur Startseite</a>

    <h:form>
        <h:panelGrid columns="2">
            <h:outputLabel value="Breitengrad (Latitude):"/>
            <h:inputText value="#{meldeBean.latitude}" required="true"/>

            <h:outputLabel value="Längengrad (Longitude):"/>
            <h:inputText value="#{meldeBean.longitude}" required="true"/>

            <h:outputLabel value="Geschätzte Größe:"/>
            <h:selectOneMenu value="#{meldeBean.groesse}" required="true">
                <f:selectItem itemLabel="-- bitte wählen --" itemValue=""/>
                <f:selectItems value="#{meldeBean.groesse.values()}" 
                               var="g" itemLabel="#{g}" itemValue="#{g}"/>
            </h:selectOneMenu>

            <h:outputLabel value="Anonym melden:"/>
            <h:selectBooleanCheckbox value="#{meldeBean.anonym}"/>

            <h:outputLabel value="Name:"/>
            <h:inputText value="#{meldeBean.name}"/>

            <h:outputLabel value="Telefonnummer:"/>
            <h:inputText value="#{meldeBean.telefon}"/>
        </h:panelGrid>

        <h:commandButton value="Geisternetz melden" 
                         action="#{meldeBean.meldenAction}"/>
        <a href="/ghostnet/">Abbrechen</a>
    </h:form>
</h:body>
</html>